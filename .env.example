# =============================================================================
# UK Property API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Railway will inject REDIS_URL automatically if you add a Redis plugin.
# All other variables must be set in the Railway dashboard → Variables tab.
# =============================================================================

# --- Redis (for caching & rate limiting) ---
# Railway auto-injects this when you add a Redis plugin.
# For local development, install Redis and use:
REDIS_URL=redis://localhost:6379

# --- x402 Payment Protocol ---
# The facilitator verifies that payments are valid.
X402_FACILITATOR_URL=https://x402.org/facilitator

# Your crypto wallet address — this is where payments arrive.
PAYMENT_WALLET_ADDRESS=0xYourWalletAddressHere

# Price per API call in USD (as a string for precise decimals).
PRICE_PER_REQUEST=0.001

# --- Rate Limiting ---
# Maximum requests a single wallet can make per minute.
RATE_LIMIT_PER_MINUTE=30

# --- Caching ---
# How many seconds to keep cached postcode results (3600 = 1 hour).
CACHE_TTL_SECONDS=3600

# --- Logging ---
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG locally, INFO in production.
LOG_LEVEL=INFO

# --- Server ---
# Railway sets PORT automatically. Only change for local dev.
PORT=8000
